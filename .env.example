APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# En producción con HTTPS: 
#SESSION_SECURE_COOKIE=true
#SESSION_SAME_SITE=lax
 
# Dominios del SPA que pueden usar cookies de sesión en /api (coma-separados). Incluye host:puerto de Vite si aplica.
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1:8000,tudominio.com

# CORS: obligatorio si el SPA (p. ej. Vite :5173) llama a la API en otro origen (cookie de sesión + axios withCredentials).
# CORS_SUPPORTS_CREDENTIALS=true
# Producción: solo dominios del SPA (coma-separados). Los patrones de localhost solo aplican con APP_ENV=local.
# CORS_ALLOWED_ORIGINS=https://app.tudominio.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Vacío si sirves el SPA desde el mismo host/puerto que Laravel (sin CORS). Si usas `npm run dev` en :5173 y API en :8000:
# VITE_API_BASE_URL=http://localhost:8000
